*~

# Local scratch directories
/tmp/

# LaTeX build output. Paper figures under figures/infocom remain trackable.
/paper/*.aux
/paper/*.bbl
/paper/*.blg
/paper/*.fdb_latexmk
/paper/*.fls
/paper/*.log
/paper/*.out
/paper/*.pdf
/paper/*.synctex.gz
/paper/*.toc
/paper/_minted-*/

# Previous thesis sources are local idea references, not INFOCOM artifacts.
/paper/archive/fyp_main.tex
/paper/archive/refs.bib

# Data are ignored by default. Only measured artifacts declared in
# reproducibility/formal_artifacts.json are admitted as paper evidence.
data/*
